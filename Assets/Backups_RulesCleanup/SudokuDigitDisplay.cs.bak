using UnityEngine;
using UnityEngine.UI;
using System.Collections;
using System.Collections.Generic;

/// <summary>
/// セルやボタンの数字表示を制御するクラス。
/// メカニカルなアニメーション（ニキシー管の切り替えなど）をサポートします。
/// </summary>
public class SudokuDigitDisplay : MonoBehaviour
{
    [Header("Components")]
    [SerializeField] private Image _targetImage;
    public Image baseImage; // 背景Image（ボタンの土台など）

    [Header("Settings")]
    public float animationSpeed = 0.5f;
    public bool HideZero = false; // 0を表示しない（ブランクにする）設定
    private int _lastValue = -1;

    private void Awake() {
        EnsureComponent();
    }

    private void EnsureComponent()
    {
        if (_targetImage == null)
        {
            // まず「DigitImage」という名前の子を探す（セル構造への配慮）
            Transform child = transform.Find("DigitImage");
            if (child != null)
            {
                _targetImage = child.GetComponent<Image>();
            }
            
            // いなければ自分自身の Image を使う（HUD構造への配慮）
            if (_targetImage == null)
            {
                _targetImage = GetComponent<Image>();
            }

            // 数字部分がクリックを邪魔しないように RaycastTarget を強制オフにする
            if (_targetImage != null)
            {
                _targetImage.raycastTarget = false;
            }
        }
        
        if (baseImage == null) {
            baseImage = GetComponent<Image>();
            if (baseImage == _targetImage) baseImage = null;
        }
    }

    public void SetDigit(int value, SudokuData.SudokuTheme theme, bool instant = false, bool forceRefresh = false) {
        Debug.Log($"[LIFE-LOG] SudokuDigitDisplay.SetDigit ENTER: value={value}, instant={instant}");
        Debug.Log($"[DIAGNOSTIC] SudokuDigitDisplay.SetDigit: Value={value}, Instant={instant}, force={forceRefresh}");

        if (string.IsNullOrEmpty(theme.themeName)) {
            if (SudokuThemeManager.Instance != null) {
                theme = SudokuThemeManager.Instance.CurrentTheme;
            } else {
                var data = UnityEditor.AssetDatabase.LoadAssetAtPath<SudokuData>("Assets/Data/SudokuData.asset");
                if (data != null) theme = data.themes[data.selectedThemeIndex];
            }
            Debug.Log($"[DIAGNOSTIC]   - Theme resolved to: {theme.themeName}");
        }

        if (instant) {
            _lastValue = value;
            ApplyVisual(value, theme);
            return;
        }

        if (_lastValue != value || forceRefresh) {
            if (gameObject.activeInHierarchy) {
                Debug.Log($"[DIAGNOSTIC]   - Starting Animation for {value}");
                StopAllCoroutines();
                StartCoroutine(AnimateDigit(value, theme));
            } else {
                Debug.Log($"[DIAGNOSTIC]   - Object inactive, applying visual instantly.");
                ApplyVisual(value, theme);
            }
            _lastValue = value;
        } else {
            Debug.Log($"[DIAGNOSTIC]   - Value {value} is same as last, skipping animation.");
        }
    }

    public void RefreshUI() {
        if (SudokuThemeManager.Instance != null) {
            ApplyVisual(_lastValue, SudokuThemeManager.Instance.CurrentTheme);
        }
    }

    private IEnumerator AnimateDigit(int value, SudokuData.SudokuTheme theme) {
        Debug.Log($"[ANIM-LOG] Start AnimateDigit: Target={value}, Theme={theme.themeName}");
        
        try {
            if (theme.displayType == SudokuData.ThemeDisplayType.Normal) {
                ApplyVisual(value, theme);
                yield return null;
            } else if (theme.displayType == SudokuData.ThemeDisplayType.LED7Seg) {
                ApplyVisual(value, theme);
                yield return null;
            } else if (theme.displayType == SudokuData.ThemeDisplayType.Nixie) {
                int[] sovietOrder = { 1, 6, 2, 7, 5, 0, 4, 9, 8, 3 }; 
                int targetPos = System.Array.IndexOf(sovietOrder, value);
                int startIdx = sovietOrder.Length - 1;
                
                Debug.Log($"[ANIM-LOG] Nixie Sequence: StartIdx={startIdx}, TargetPos={targetPos}");
                for (int i = startIdx; i >= targetPos; i--) {
                    Debug.Log($"[ANIM-LOG] Nixie Step: Showing {sovietOrder[i]} (i={i})");
                    ApplyVisual(sovietOrder[i], theme);
                    yield return new WaitForSeconds(0.02f);
                }
            } else if (theme.displayType == SudokuData.ThemeDisplayType.Mechanical) {
                int start = _lastValue >= 0 ? _lastValue : 0;
                int end = value;
                if (start > end) end += 10;
                
                Debug.Log($"[ANIM-LOG] Mechanical Sequence: Start={start}, End={end}");
                for (int v = start; v <= end; v++) {
                    Debug.Log($"[ANIM-LOG] Mechanical Step: Showing {v % 10}");
                    ApplyVisual(v % 10, theme);
                    yield return new WaitForSeconds(0.05f);
                }
            }
        } finally {
            _lastValue = value;
            Debug.Log($"[ANIM-LOG] End AnimateDigit: Finished at {value}");
        }
    }

    private Sprite GetThemeSprite(int value, SudokuData.SudokuTheme theme) {
        if (value == -2) return FindSpriteInTheme(theme, "Clear");
        if (value == 10) return FindSpriteInTheme(theme, "Blank");
        
        if (value <= 0) {
            if (HideZero) return FindSpriteInTheme(theme, "Blank");
            else return FindSpriteInTheme(theme, "0");
        }
        
        return FindSpriteInTheme(theme, value.ToString());
    }

    private Sprite FindSpriteInTheme(SudokuData.SudokuTheme theme, string spriteName) {
        if (theme.sprites == null) return null;
        foreach (var s in theme.sprites) {
            if (s != null) {
                if (s.name == spriteName) return s;
                if (s.name.EndsWith(spriteName)) {
                    // "11"の末尾が"1"であるために誤ヒットするのを防ぐため、直前の文字が数字でないことを確認
                    if (s.name.Length > spriteName.Length) {
                        char prevChar = s.name[s.name.Length - spriteName.Length - 1];
                        if (char.IsDigit(prevChar)) continue; 
                    }
                    return s;
                }
            }
        }
        return null;
    }

    private void ApplyVisual(int value, SudokuData.SudokuTheme theme) {
        if (_targetImage == null) EnsureComponent();
        if (_targetImage == null) return;
        
        int displayValue = value;
        if (HideZero && value == 0) displayValue = 10; 
        if (value < 0 && value != -2) displayValue = 10;

        Sprite s = GetThemeSprite(displayValue, theme);

        TMPro.TextMeshProUGUI textLabel = null;
        Transform t = transform.Find("TextLabel");
        if (t != null) textLabel = t.GetComponent<TMPro.TextMeshProUGUI>();

        if (s == null) {
            _targetImage.sprite = null;
            _targetImage.color = new Color(0,0,0,0); // 完全に透明にする
            
            if (displayValue != -1) {
                if (textLabel == null) t = CreateTextLabel();
                if (t != null) textLabel = t.GetComponent<TMPro.TextMeshProUGUI>();
                
                if (textLabel != null) {
                    textLabel.enabled = true;
                    if (displayValue == -2) textLabel.text = "C";
                    else if (displayValue == 10 || displayValue <= 0) textLabel.text = "";
                    else textLabel.text = displayValue.ToString();
                    textLabel.color = theme.textColor;
                    textLabel.fontSize = 32;
                    textLabel.alignment = TMPro.TextAlignmentOptions.Center;
                }
            } else if (textLabel != null) {
                textLabel.enabled = false;
            }
        } else {
            _targetImage.sprite = s;
            _targetImage.material = null;
            if (textLabel != null) textLabel.enabled = false;

            if (theme.displayType == SudokuData.ThemeDisplayType.Nixie) {
                int[] sovietOrder = { 1, 2, 6, 7, 5, 0, 4, 9, 8, 3 };
                int depthIndex = System.Array.IndexOf(sovietOrder, displayValue);
                float brightness = 1.0f;
                if (depthIndex != -1) {
                    brightness = Mathf.Lerp(1.0f, 0.8f, (float)depthIndex / (sovietOrder.Length - 1));
                }
                _targetImage.color = theme.textColor * brightness;
                _targetImage.rectTransform.localScale = Vector3.one;
            } else {
                _targetImage.color = theme.textColor;
                _targetImage.rectTransform.localScale = Vector3.one;
            }
        }
    }

    private Transform CreateTextLabel() {
        GameObject go = new GameObject("TextLabel");
        go.transform.SetParent(transform, false);
        var txt = go.AddComponent<TMPro.TextMeshProUGUI>();
        txt.raycastTarget = false;
        
        RectTransform rt = go.GetComponent<RectTransform>();
        rt.anchorMin = Vector2.zero;
        rt.anchorMax = Vector2.one;
        rt.sizeDelta = Vector2.zero;
        
        return go.transform;
    }

    private void OnEnable() {
        if (SudokuThemeManager.Instance != null) {
            RefreshUI();
        }
    }
}
