  m_text: "<b>\u3010\u6570\u72EC\uFF08SUDOKU\uFF09\u306E\u57FA\u672C\u30EB\u30FC\u30EB\u3011</b>\n\u30FB\u7E269\u5217\u3001\u6A2A9\u884C\u3001\u592A\u7DDA\u3067\u56F2\u307E\u308C\u305F3x3\u306E\u30D6\u30ED\u30C3\u30AF\u305D\u308C\u305E\u308C\u306B\u30011\u304B\u30899\u307E\u3067\u306E\u6570\u5B57\u304C\u91CD\u8907\u3057\u306A\u3044\u3088\u3046\u306B\u5165\u308A\u307E\u3059\u3002\n\u30FB\u6700\u521D\u304B\u3089\u914D\u7F6E\u3055\u308C\u3066\u3044\u308B\u6570\u5B57\u306F\u5909\u66F4\u3067\u304D\u307E\u305B\u3093\u3002\n\n<b>\u3010\u30B2\u30FC\u30E0\u306E\u64CD\u4F5C\u65B9\u6CD5\u3011</b>\n1.
    \u76E4\u9762\uFF089x9\uFF09\u306E\u7A7A\u3044\u3066\u3044\u308B\u30BB\u30EB\u3092\u30BF\u30C3\u30D7\u3057\u3066\u9078\u629E\u3057\u307E\u3059\u3002\u9078\u629E\u3055\u308C\u305F\u30BB\u30EB\u306F\u67A0\u7DDA\u3067\u5F37\u8ABF\u3055\u308C\u307E\u3059\u3002\n2.
    \u753B\u9762\u4E0B\u90E8\u306E\u5165\u529B\u30D1\u30CD\u30EB\uFF081\u301C9\uFF09\u304B\u3089\u6570\u5B57\u3092\u30BF\u30C3\u30D7\u3057\u3066\u5165\u529B\u3057\u307E\u3059\u3002\n3.
