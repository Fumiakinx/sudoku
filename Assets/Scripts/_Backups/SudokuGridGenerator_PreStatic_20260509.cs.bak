using System.Collections.Generic;
using UnityEngine;
using UnityEngine.UI;

/// <summary>
/// Sudokuの盤面オブジェクト（セルやブロック）の生成とレイアウトのみを担当するクラス
/// </summary>
// [ExecuteAlways]
public class SudokuGridGenerator : MonoBehaviour {
    [SerializeField] private GameObject cellPrefab;
    [SerializeField] public Transform gridParent;

    private bool isGenerating = false;

    public void Generate(SudokuBoard board, int[,] puzzle) {
        if (isGenerating) return;
        isGenerating = true;
        Debug.Log($"[SudokuGridGenerator] Generate started (Static Persistence Mode)");

        try {
            if (gridParent == null) {
                Debug.LogError("[SudokuGridGenerator] gridParent is null!");
                return;
            }
            
            // 既存のセルを再利用するために、現在の階層をスキャン
            // (破壊は絶対に行わない。もし足りない場合のみ生成する)
            List<SudokuCell> existingCells = new List<SudokuCell>();
            foreach (Transform block in gridParent) {
                foreach (Transform cellTransform in block) {
                    SudokuCell c = cellTransform.GetComponent<SudokuCell>();
                    if (c != null) existingCells.Add(c);
                }
            }

            // セルが既に81個あるなら、生成をスキップしてデータのみ更新
            bool alreadyBuilt = (existingCells.Count == 81);
            
            RectTransform containerRT = gridParent.GetComponent<RectTransform>();
            float cellSize = SudokuUIConstants.CELL_SIZE;
            float blockSpacing = 10f;
            float blockSize = (cellSize * 3f);
            float totalBoardSize = (blockSize * 3f) + (blockSpacing * 2f);
            containerRT.sizeDelta = new Vector2(totalBoardSize, totalBoardSize);
            float startOffset = -totalBoardSize / 2f + blockSize / 2f;

            if (!alreadyBuilt) {
                Debug.Log("[SudokuGridGenerator] 既存の盤面が見つからないため、初回生成を行います。");
                BuildGridHierarchy(board, puzzle, blockSize, blockSpacing, cellSize, startOffset);
            } else {
                Debug.Log("[SudokuGridGenerator] 既存の盤面を再利用します。");
                UpdateGridData(board, puzzle);
            }
            
            // 生成/更新完了後にUIをリフレッシュ
            if (SudokuUIController.Instance != null) {
                SudokuUIController.Instance.Refresh();
            }
        } finally {
            isGenerating = false;
        }
    }

    private void BuildGridHierarchy(SudokuBoard board, int[,] puzzle, float blockSize, float blockSpacing, float cellSize, float startOffset) {
        for (int bR = 0; bR < 3; bR++) {
            for (int bC = 0; bC < 3; bC++) {
                int blockIndex = bR * 3 + bC;
                GameObject blockGo = new GameObject($"Block_{blockIndex}", typeof(RectTransform));
                blockGo.transform.SetParent(gridParent, false);
                
                var rt = blockGo.GetComponent<RectTransform>();
                rt.anchorMin = rt.anchorMax = rt.pivot = new Vector2(0.5f, 0.5f);
                rt.sizeDelta = new Vector2(blockSize, blockSize);
                
                float posX = startOffset + bC * (blockSize + blockSpacing);
                float posY = -(startOffset + bR * (blockSize + blockSpacing));
                rt.anchoredPosition = new Vector2(posX, posY); 

                float cStartOffset = -blockSize / 2f + cellSize / 2f;

                for (int r = 0; r < 3; r++) {
                    for (int c = 0; c < 3; c++) {
                        int globalR = bR * 3 + r;
                        int globalC = bC * 3 + c;
                        
                        GameObject cellObj = Instantiate(cellPrefab, blockGo.transform);
                        cellObj.name = $"Cell_{globalR}_{globalC}";
                        
                        var cellRT = cellObj.GetComponent<RectTransform>();
                        cellRT.anchorMin = cellRT.anchorMax = cellRT.pivot = new Vector2(0.5f, 0.5f);
                        cellRT.sizeDelta = new Vector2(cellSize, cellSize);
                        
                        float cPosX = cStartOffset + c * cellSize;
                        float cPosY = -(cStartOffset + r * cellSize);
                        cellRT.anchoredPosition = new Vector2(cPosX, cPosY);

                        SudokuCell cell = cellObj.GetComponent<SudokuCell>();
                        if (cell != null) {
                            cell.Init(globalR, globalC, puzzle[globalR, globalC], puzzle[globalR, globalC] != 0, board);
                            board.cells[globalR, globalC] = cell;
                            
                            var button = cellObj.GetComponent<Button>();
                            if (button != null) {
                                button.onClick.RemoveAllListeners();
                                button.onClick.AddListener(() => board.SelectCell(cell));
                            }
                        }
                    }
                }
            }
        }
    }

    private void UpdateGridData(SudokuBoard board, int[,] puzzle) {
        // 名前を元に全セルを取得し、データを更新
        SudokuCell[] cells = gridParent.GetComponentsInChildren<SudokuCell>(true);
        foreach (var cell in cells) {
            if (cell != null) {
                int r = cell.Row;
                int c = cell.Col;
                cell.Init(r, c, puzzle[r, c], puzzle[r, c] != 0, board);
                board.cells[r, c] = cell;
            }
        }
    }
}
